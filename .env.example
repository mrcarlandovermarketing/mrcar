# Mr. Car - Configuración de Variables de Entorno

# Origen de datos para el inventario ('mock' o 'apps-script')
VEHICLE_DATA_SOURCE=mock

# URL de la API de Google Apps Script (Servidor-side únicamente, no usar prefijo NEXT_PUBLIC)
# Ejemplo: APPS_SCRIPT_API_URL=https://script.google.com/macros/s/AKfycbx_XYZ/exec
APPS_SCRIPT_API_URL=

# Tiempo de revalidación del caché HTTP en segundos (defecto a 300 segundos = 5 minutos)
APPS_SCRIPT_REVALIDATE_SECONDS=300

# Permite fallback a datos mock en desarrollo si falta configurar la URL (true/false)
ALLOW_DEV_FALLBACK=true

# Clave secreta para guardar leads y mensajes en Google Sheets (No usar prefijo NEXT_PUBLIC)
APPS_SCRIPT_WRITE_SECRET=

# Token de autenticación de OpenRouter (Confidencial, servidor-side únicamente)
OPENROUTER_API_KEY=

# Modelo seleccionado para respuestas (defecto: openrouter/free)
OPENROUTER_MODEL=openrouter/free

# Metadatos del sitio solicitados por OpenRouter
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=MrCarWebApp
